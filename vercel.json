{
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/api/:path*/",
      "destination": "https://delta-backend-ohze.onrender.com/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://delta-backend-ohze.onrender.com/api/:path*/"
    },
    {
      "source": "/((?!assets/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
